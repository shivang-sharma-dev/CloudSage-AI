# CloudSage AI — Environment Variables
# Copy this file to .env in the root and fill in values

# ─── Anthropic Claude (if using Claude) ─────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Google Gemini (free alternative to Claude) ──────────
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# ─── Groq (free, Llama 3.1 70B) ─────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your-groq-key-here

# ─── AI Provider switch ───────────────────────────────────
AI_PROVIDER=gemini   # gemini | claude | groq | ollama

# ─── Frontend ────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
