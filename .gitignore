# ─── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# ─── Node / Frontend ─────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# ─── Environment & Secrets (NEVER commit) ────────────────
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key

# ─── Docker ──────────────────────────────────────────────
# (docker-compose.yml IS committed — override files are not)
docker-compose.override.yml

# ─── Database ────────────────────────────────────────────
*.sqlite
*.db
postgres_data/

# ─── Editor / OS ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Alembic runtime ─────────────────────────────────────
# Migration version files ARE committed — only pycache is excluded
backend/alembic/__pycache__/
backend/alembic/versions/__pycache__/
